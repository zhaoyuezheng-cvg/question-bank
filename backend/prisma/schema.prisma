// Prisma Schema for Question Bank System
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./question-bank.db"
}

model Question {
  id          String   @id
  subject     String
  category    String
  subCategory String
  type        String
  subType     String?  // 阅读理解细分题型，如：句子赏析、推理判断
  difficulty  Int
  content     String
  options     String?  // JSON array string
  answer      String
  analysis    String
  tags        String?  // JSON array string
  source      String?
  passageId   String?  // 关联阅读材料
  createdAt   Int
  updatedAt   Int

  // Relations
  passage         Passage?       @relation(fields: [passageId], references: [id], onDelete: SetNull)
  paperItems      PaperQuestion[]
  errorItems      ErrorBook[]
  favorites       Favorite[]
  flashcards      Flashcard[]
  practiceRecords PracticeRecord[]
  notes           QuestionNote[]

  @@index([subject])
  @@index([category])
  @@index([subCategory])
  @@index([type])
  @@index([difficulty])
  @@index([passageId])
}

// ---- 阅读材料 ----
model Passage {
  id          String   @id
  title       String   // 材料标题，如：《背影》阅读理解
  subject     String   // 学科
  category    String   // 一级分类：现代文阅读/古诗文阅读/阅读理解/...
  subCategory String   // 二级分类：小说阅读/散文阅读/文言文阅读/...
  content     String   // 文章正文（Markdown/LaTeX/图片）
  source      String?  // 来源
  tags        String?  // JSON array
  createdAt   Int
  updatedAt   Int

  // Relations
  questions   Question[]

  @@index([subject])
  @@index([category])
  @@index([subCategory])
}

model ExamPaper {
  id          String   @id
  title       String
  description String?
  subject     String
  totalScore  Int?
  showAnalysis Boolean @default(true)
  showAnswer   Boolean @default(false)
  answerAreaLines Int   @default(5)
  fontSize    Int      @default(14)
  headerText  String?
  footerText  String?
  createdAt   Int
  updatedAt   Int

  // Relations
  questions   PaperQuestion[]

  @@index([subject])
}

model PaperQuestion {
  id        String    @id
  paperId   String
  questionId String
  order     Int
  score     Int?

  paper     ExamPaper  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  question  Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([paperId, questionId])
  @@index([paperId])
  @@index([questionId])
}

model Tag {
  id    String @id
  name  String @unique
  color String?
}

model Category {
  id        String @id
  subject   String
  name      String
  parentId  String?
  isPassage Boolean @default(false)  // 是否为阅读材料分类

  @@index([subject])
  @@index([parentId])
  @@unique([subject, name, parentId])
}

// ---- 错题本 ----
model ErrorBook {
  id          String @id
  questionId  String
  userId      String?  // 所属用户
  wrongAnswer String  // 用户的错误答案
  errorNote   String? // 错误原因备注
  isResolved  Boolean @default(false) // 是否已掌握
  // SM-2 间隔重复调度
  easeFactor  Float   @default(2.5)
  interval    Int     @default(1)    // 当前间隔（天）
  repetitions Int     @default(0)    // 连续正确次数
  nextReview  Int     // 下次复习时间（unix timestamp）
  lastReview  Int?    // 上次复习时间
  createdAt   Int
  updatedAt   Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([questionId])
  @@index([isResolved])
  @@index([userId])
  @@index([nextReview])
}

// ---- 收藏夹 ----
model Favorite {
  id         String @id
  questionId String
  userId     String?  // 所属用户
  note       String? // 收藏备注
  createdAt  Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([questionId])
  @@index([userId])
  @@unique([questionId, userId])
}

// ---- 答题记录 ----
model PracticeRecord {
  id          String @id
  questionId  String
  userId      String?  // 所属用户
  userAnswer  String
  isCorrect   Boolean
  timeSpent   Int? // 用时（秒）
  createdAt   Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([questionId])
  @@index([isCorrect])
  @@index([createdAt])
  @@index([userId])
}

// ---- 考试模拟 ----
model ExamSession {
  id          String @id
  paperId     String
  title       String
  subject     String
  totalScore  Int
  timeLimit   Int     // 时间限制（分钟）
  answers     String? // JSON: { questionId: userAnswer }
  score       Int?    // 得分
  correctCount Int?
  totalCount  Int
  status      String  @default("in_progress") // in_progress | completed | timeout
  startedAt   Int
  completedAt Int?
  createdAt   Int

  @@index([status])
  @@index([createdAt])
}

// ---- 闪卡复习 ----
model Flashcard {
  id          String @id
  questionId  String
  easeFactor  Float   @default(2.5)  // SM-2 ease factor
  interval    Int     @default(0)    // 当前间隔（天）
  repetitions Int     @default(0)    // 重复次数
  nextReview  Int     // 下次复习时间（unix timestamp）
  lastReview  Int?
  createdAt   Int
  updatedAt   Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId])
  @@index([nextReview])
}

// ---- 试卷模板 ----
model PaperTemplate {
  id          String @id
  name        String
  description String?
  subject     String
  config      String  // JSON: layoutConfig + filters
  createdAt   Int
  updatedAt   Int

  @@index([subject])
}

// ---- 英语单词 ----
model WordBook {
  id          String @id
  word        String  // 英文单词
  phonetic    String? // 音标
  meaning     String  // 中文释义
  partOfSpeech String? // 词性
  example     String? // 例句
  unit        String? // 所属单元，如：Unit 1
  subject     String  @default("english")
  mastery     Int     @default(0) // 掌握度 0-5
  nextReview  Int     // 下次复习时间
  reviewCount Int     @default(0)
  createdAt   Int
  updatedAt   Int

  @@unique([word, subject])
  @@index([unit])
  @@index([nextReview])
  @@index([mastery])
}

// ---- 学习计划 ----
model StudyPlan {
  id          String @id
  date        String   // YYYY-MM-DD
  subject     String
  targetCount Int      // 目标题数
  doneCount   Int      @default(0) // 完成题数
  status      String   @default("pending") // pending | done | skipped
  createdAt   Int
  updatedAt   Int

  @@unique([date, subject])
  @@index([date])
}

model StudyCheckin {
  id        String @id
  date      String @unique // YYYY-MM-DD
  totalDone Int    @default(0) // 当日完成总题数
  streak    Int    @default(0) // 连续天数
  createdAt Int
}

// ---- 题目关联 ----
// ---- 用户 ----
model User {
  id           String @id
  username     String @unique
  passwordHash String
  role         String @default("user") // admin | user
  createdAt    Int

  // Relations
  errorBooks      ErrorBook[]
  favorites       Favorite[]
  practiceRecords PracticeRecord[]
  notes           QuestionNote[]
  auditLogs       AuditLog[]
  operationLogs   OperationLog[]
}

// ---- 审计日志 ----
model AuditLog {
  id        String @id
  userId    String?
  action    String   // 操作类型：create/update/delete/login/register
  target    String   // 操作对象：question/paper/user/...
  targetId  String?  // 操作对象ID
  detail    String?  // 详情
  ip        String?  // IP地址
  createdAt Int

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([target])
  @@index([createdAt])
}

// ---- 教材目录 ----
model TextbookCatalog {
  id        String  @id
  name      String  // 名称，如：鲁教版数学七年级
  subject   String  // 学科
  grade     String  // 年级
  version   String  // 版本，如：鲁教版/人教版
  volume    String  // 上册/下册
  chapters  String  // JSON: [{name, sections: [{name}]}]
  isDefault Boolean @default(false)
  createdAt Int
  updatedAt Int

  @@index([subject])
  @@index([grade])
}

model QuestionRelation {
  id          String @id
  questionId  String
  relatedId   String
  relationType String // "similar" | "same_knowledge" | "prerequisite"

  @@unique([questionId, relatedId])
  @@index([questionId])
  @@index([relatedId])
}

// ---- 题目笔记 ----
// ---- 操作日志（用户级） ----
model OperationLog {
  id        String @id
  userId    String
  action    String   // delete_question, update_question, delete_paper, etc.
  targetType String  // question, paper, error_book, etc.
  targetId  String?
  detail    String?  // JSON: { before, after }
  createdAt Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model QuestionNote {
  id          String @id
  questionId  String
  userId      String
  content     String   // 笔记内容（Markdown）
  createdAt   Int
  updatedAt   Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId])
  @@index([questionId])
  @@index([userId])
}
